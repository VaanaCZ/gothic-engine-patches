// When the hero transform into a monster, any attacking
// NPCs will still have their "enemy" pointer pointing
// to the hero (who is now invisible). This causes them
// to kill the player by hitting the invisible hero.
// Even worse, in Gothic 1 it causes a crash!
// Created by Vaana

#engine [G1]
    #patch [Prevent monsters from attacking transformed player]
        #assembler [0x0074AE68]
            mov     esi, [edi+37Ch]     ; enemy
            xor     ebx, ebx
            cmp     esi, ebx
            jz      return
            mov     ecx, [esi+00A8h]    ; homeWorld
            cmp     ecx, ebx
            jnz     return
            mov     ecx, edi            ; this
            push    0
            call    0x00691A80          ; SetEnemy
        return:
            orgcode
        #/assembler
    #/patch
#/engine

