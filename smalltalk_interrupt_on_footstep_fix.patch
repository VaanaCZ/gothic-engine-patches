// By default PERC_ASSESSQUIETSOUND cancels all running
// SVMs. This means player cancels NPCs smalltalk by
// walking around them. This patch disabled this. 
// Ported from Gothic 2 by Auronen, Fawkes and Vaana

#engine [G1]
    #patch [Fixed SVM interrupt on certain perceptions]
        BOOL g_bDontKillOUSound = False
        // AssessQuietSound_S
        #assembler [0x006B5BC0]
            mov     dword ptr ds:[$g_bDontKillOUSound], 1
            orgcode
            mov     dword ptr ds:[$g_bDontKillOUSound], 0
        #/assembler
        // StopRunningOU
        #assembler [0x006338B4]
            mov     eax, dword ptr ds:[$g_bDontKillOUSound]
            test    eax, eax
            jnz     0x00633A03
            orgcode
        #/assembler
    #/patch
#/engine

#engine [G1A]
    #patch [Fixed SVM interrupt on certain perceptions]
        BOOL g_bDontKillOUSound = False
        // AssessQuietSound_S
        #assembler [0x006EA430]
            mov     dword ptr ds:[$g_bDontKillOUSound], 1
            orgcode
            mov     dword ptr ds:[$g_bDontKillOUSound], 0
        #/assembler
        // StopRunningOU
        #assembler [0x00659724]
            mov     eax, dword ptr ds:[$g_bDontKillOUSound]
            test    eax, eax
            jnz     0x0065986C
            orgcode
        #/assembler
    #/patch
#/engine